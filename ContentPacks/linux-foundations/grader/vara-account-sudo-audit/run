#!/usr/bin/env python3
import argparse, sys
from pathlib import Path
sys.path.insert(0, str(Path(__file__).resolve().parents[1]))
from lib import add_ssh_args, check, emit
p = argparse.ArgumentParser(); p.add_argument('--session', required=True); add_ssh_args(p); p.add_argument('--mode', required=True); args = p.parse_args()
report = "~/work/vara/accounts/audit.txt"
checks = [
    check(args, "report-exists", "Account audit report exists", f"test -f {report}", "Create ~/work/vara/accounts/audit.txt."),
    check(args, "locked-account", "Locked account identified", f"grep -qE '^LOCKED_ACCOUNT=opslocked[[:space:]]*$' {report} && sudo awk -F: '$1==\"opslocked\" && $2 ~ /^!/ {{found=1}} END {{exit !found}}' /etc/shadow", "Set LOCKED_ACCOUNT=opslocked from local evidence."),
    check(args, "unexpected-sudo", "Unexpected sudo account identified", f"grep -qE '^UNEXPECTED_SUDO_ACCOUNT=tempadmin[[:space:]]*$' {report}", "Set UNEXPECTED_SUDO_ACCOUNT=tempadmin from group membership evidence."),
    check(args, "evidence-present", "Evidence section included", f"grep -qE '^EVIDENCE:' {report} && grep -qiE '(shadow|sudo|group|passwd)' {report}", "Add an EVIDENCE: section with supporting observations."),
    check(args, "sudo-removed", "Unexpected sudo access removed", "! id -nG tempadmin | grep -qw sudo", "Remove sudo access from the unexpected account."),
    check(args, "learner-intact", "Learner sudo access preserved", "id -nG learner | grep -qw sudo", "Do not remove the learner account's operator access."),
]
emit("vara-account-sudo-audit", checks)
