#!/usr/bin/env python3
import argparse, sys
from pathlib import Path
sys.path.insert(0, str(Path(__file__).resolve().parents[1]))
from lib import add_ssh_args, check, emit
p = argparse.ArgumentParser(); p.add_argument('--session', required=True); add_ssh_args(p); p.add_argument('--mode', required=True); args = p.parse_args()
errors='~/work/logs/errors.txt'
checks=[
 check(args,'error-log-report','ERROR lines captured',f'grep -Fq "2026-06-12T10:01:00Z ERROR queue stalled shard=blue" {errors} && grep -Fq "2026-06-12T10:02:00Z ERROR retry budget exhausted shard=green" {errors}','Copy every ERROR line from /var/log/opscoach/worker.log into ~/work/logs/errors.txt exactly.'),
 check(args,'agent-active','opscoach-agent is active','sudo systemctl is-active --quiet opscoach-agent.service','Start opscoach-agent.service.'),
 check(args,'agent-enabled','opscoach-agent is enabled','sudo systemctl is-enabled --quiet opscoach-agent.service','Enable opscoach-agent.service.'),
 check(args,'agent-ready','Agent wrote readiness file','test -f /run/opscoach/agent.ready','The active agent should create /run/opscoach/agent.ready.'),
]
emit('logs-systemd',checks)
