#!/usr/bin/env python3
import argparse, sys
from pathlib import Path
sys.path.insert(0, str(Path(__file__).resolve().parents[1]))
from lib import add_ssh_args, check, emit
p = argparse.ArgumentParser(); p.add_argument('--session', required=True); add_ssh_args(p); p.add_argument('--mode', required=True); args = p.parse_args()
report = "~/work/vara/network/listeners.txt"
checks = [
    check(args, "report-exists", "Listener report exists", f"test -f {report}", "Create ~/work/vara/network/listeners.txt."),
    check(args, "port-recorded", "Unexpected port recorded", f"grep -qE '^PORT=9091[[:space:]]*$' {report}", "Set PORT=9091 for the debug listener."),
    check(args, "process-recorded", "Process name recorded", f"grep -qE '^PROCESS=' {report} && (grep -qE '^PROCESS=vara-debug-listener[[:space:]]*$' {report} || grep -qE '^PROCESS=python3?[[:space:]]*$' {report})", "Set PROCESS= to the listener process name (vara-debug-listener or python)."),
    check(args, "unit-evidence", "Owning unit recorded", f"grep -qE '^UNIT=vara-debug-listener\\.service[[:space:]]*$' {report}", "Set UNIT=vara-debug-listener.service."),
    check(args, "debug-stopped", "Debug listener is stopped", "sudo systemctl is-active --quiet vara-debug-listener.service; test $? -ne 0", "Stop the unexpected listener's service."),
    check(args, "debug-disabled", "Debug listener is disabled", "sudo systemctl is-enabled --quiet vara-debug-listener.service; test $? -ne 0", "Disable the unexpected listener's service."),
    check(args, "api-preserved", "Expected API remains available", "curl -fsS http://127.0.0.1:8080/health | grep -q 'opscoach-api ok'", "Keep the expected local API available."),
]
emit("vara-ports-processes", checks)
