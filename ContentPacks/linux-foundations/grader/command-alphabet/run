#!/usr/bin/env python3
import argparse
import json

LAB_ID = "command-alphabet"


def parse_args():
    parser = argparse.ArgumentParser()
    parser.add_argument("--session", required=True)
    parser.add_argument("--ssh-key", required=True)
    parser.add_argument("--ssh-port", required=True)
    parser.add_argument("--ssh-user", required=True)
    parser.add_argument("--ssh-hostname", required=True)
    parser.add_argument("--known-hosts", required=True)
    parser.add_argument("--mode", required=True)
    return parser.parse_args()


def main():
    parse_args()
    checks = [{
        "id": "ui-only",
        "status": "warning",
        "label": "Progress tracked in Command Alphabet panel",
        "detail": "No SSH session or host checks — click Open Game and complete all 26 letters in the panel.",
    }]
    print(json.dumps({"labId": LAB_ID, "checks": checks, "score": {"passed": 0, "total": 1}}))


if __name__ == "__main__":
    main()
