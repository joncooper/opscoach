#!/usr/bin/env python3
import argparse, sys
from pathlib import Path
sys.path.insert(0, str(Path(__file__).resolve().parents[1]))
from lib import add_ssh_args, check, emit
p = argparse.ArgumentParser(); p.add_argument('--session', required=True); add_ssh_args(p); p.add_argument('--mode', required=True); args = p.parse_args()
report='~/work/orientation/summary.txt'
checks=[
 check(args,'summary-exists','Orientation summary exists',f'test -s {report}','Create ~/work/orientation/summary.txt.'),
 check(args,'identity','Summary records user and host',f'grep -q learner {report} && grep -q "$(hostname)" {report}','Include learner and the host name.'),
 check(args,'welcome-path','Summary includes welcome.txt path',f'grep -q /opt/opscoach/reference/welcome.txt {report}','Find and record the absolute path to the Ops Coach welcome.txt file.'),
 check(args,'kernel-home','Summary includes kernel and home',f'grep -qi linux {report} && grep -q /home/learner {report}','Include kernel name and home directory.'),
 check(args,'ordered-facts','Summary lists facts in order',f'test $(wc -l < {report}) -ge 5 && sed -n "1p" {report} | grep -qx learner && sed -n "2p" {report} | grep -qx "$(hostname)" && sed -n "3p" {report} | grep -qx /home/learner && sed -n "4p" {report} | grep -qi linux && sed -n "5p" {report} | grep -q /opt/opscoach/reference/welcome.txt','Put one fact per line in order: username, hostname, home, kernel name, then welcome path.'),
]
emit('shell-orientation',checks)
