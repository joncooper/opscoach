#!/usr/bin/env python3
import argparse, sys
from pathlib import Path
sys.path.insert(0, str(Path(__file__).resolve().parents[1]))
from lib import add_ssh_args, check, emit
p = argparse.ArgumentParser(); p.add_argument('--session', required=True); add_ssh_args(p); p.add_argument('--mode', required=True); args = p.parse_args()
checks=[
 check(args,'operator-user','Operator login exists','getent passwd opsoperator >/dev/null','Create the opsoperator account.'),
 check(args,'operator-groups','Operator has required access','id -nG opsoperator | grep -qw ops && id -nG opsoperator | grep -qw sudo','opsoperator should belong to the ops team and have normal sudo-capable operator access.'),
 check(args,'authorized-key','Operator SSH key installed','sudo test -f /home/opsoperator/.ssh/authorized_keys && sudo cmp -s /home/opsoperator/.ssh/authorized_keys /opt/opscoach/reference/operator_ed25519.pub','Install the supplied operator public key as the account authorized key.'),
 check(args,'ssh-permissions','Operator SSH key is protected',"sudo sh -c 'test \"$(stat -c %a /home/opsoperator/.ssh)\" = 700 && test \"$(stat -c %a /home/opsoperator/.ssh/authorized_keys)\" = 600'",'Protect the operator SSH directory and authorized key file with strict modes.'),
 check(args,'ssh-ownership','Operator owns SSH directory',"sudo sh -c 'test \"$(stat -c %U /home/opsoperator/.ssh)\" = opsoperator'",'Set ownership of /home/opsoperator/.ssh to opsoperator.'),
 check(args,'sudoers-group','Status sudo uses ops group','sudo grep -R "%ops" /etc/sudoers.d | grep -q "systemctl status opscoach-agent.service" && sudo grep -R "%ops" /etc/sudoers.d | grep -q NOPASSWD && sudo visudo -cf /etc/sudoers >/dev/null','Add a valid sudoers rule granting the ops group passwordless systemctl status for opscoach-agent only.'),
 check(args,'sudoers-no-lifecycle','Lifecycle sudo is not passwordless',"sudo sh -c 'if grep -RihE \"NOPASSWD\" /etc/sudoers.d | grep -Ei \"(start|stop|restart)\" | grep -qi \"opscoach-agent\"; then exit 1; else exit 0; fi'",'Do not grant passwordless start, stop, or restart for opscoach-agent in sudoers.d.'),
 check(args,'sudoers-no-broad-systemctl','Broad systemctl sudo is not passwordless',"sudo sh -c 'if grep -RihE \"NOPASSWD.*(/usr/bin/systemctl|systemctl)[[:space:]]*$\" /etc/sudoers.d; then exit 1; else exit 0; fi'",'Do not grant passwordless access to all systemctl subcommands.'),
 check(args,'sudo-status-works','Operator can inspect agent status',"sudo sh -c 'code=0; sudo -u opsoperator sudo -n $(command -v systemctl) status opscoach-agent.service >/dev/null 2>&1 || code=$?; test $code -eq 0 -o $code -eq 3'",'opsoperator should run passwordless systemctl status opscoach-agent.service (inactive units may exit 3).'),
 check(args,'sudo-start-blocked','Operator cannot start agent',"sudo sh -c '! sudo -u opsoperator sudo -n $(command -v systemctl) start opscoach-agent.service 2>/dev/null'",'opsoperator must not have passwordless permission to start opscoach-agent.service.'),
 check(args,'sudo-stop-blocked','Operator cannot stop agent',"sudo sh -c '! sudo -u opsoperator sudo -n $(command -v systemctl) stop opscoach-agent.service 2>/dev/null'",'opsoperator must not have passwordless permission to stop opscoach-agent.service.'),
 check(args,'sudo-restart-blocked','Operator cannot restart agent',"sudo sh -c '! sudo -u opsoperator sudo -n $(command -v systemctl) restart opscoach-agent.service 2>/dev/null'",'opsoperator must not have passwordless permission to restart opscoach-agent.service.'),
]
emit('users-ssh-sudo',checks)
