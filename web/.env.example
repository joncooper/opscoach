# OpsCoach web app — example environment.
# Copy to `web/.env` and fill in. Everything here has a safe default or is optional unless
# noted; the app runs locally in mock mode with almost none of these set.

# ---------------------------------------------------------------------------
# Access gate (post-auth shared passphrase — see web/lib/gate.ts)
# ---------------------------------------------------------------------------
# Opaque token written to the gate cookie once the code is accepted. Use a long random
# value in production, e.g. `openssl rand -hex 24`. Defaults to "dev-change-me" if unset.
GATE_TOKEN=
# Accepted answers, comma-separated. Matching is case- and punctuation-insensitive.
GATE_ANSWERS=your secret phrase
# Prompt shown on the /gate boot screen (public — exposed to the browser).
NEXT_PUBLIC_GATE_PROMPT=ACCESS CODE REQUIRED

# ---------------------------------------------------------------------------
# Datastore (optional — an in-memory store is used when DATABASE_URL is unset)
# ---------------------------------------------------------------------------
DATABASE_URL=postgres://opscoach:opscoach@localhost:5432/opscoach
# Discrete connection parts (used only if DATABASE_URL is not set):
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_NAME=opscoach
DATABASE_USER=opscoach
DATABASE_PASSWORD=
# TLS: set DATABASE_SSL=true to require TLS; supply a CA inline or by path if needed.
DATABASE_SSL=
DATABASE_CA=
DATABASE_CA_PATH=

# ---------------------------------------------------------------------------
# Content + session storage
# ---------------------------------------------------------------------------
# Content packs root (relative to repo root or absolute)
CONTENT_ROOT=../ContentPacks
# Session workspace on disk
SESSIONS_ROOT=/tmp/opscoach-sessions

# ---------------------------------------------------------------------------
# AWS / region
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1
# Overrides AWS_REGION for OpsCoach-specific calls when set.
OPSCOACH_REGION=us-east-1

# ---------------------------------------------------------------------------
# EC2 lab provisioning (omit all for local mock mode)
# ---------------------------------------------------------------------------
EC2_LAUNCH_TEMPLATE_ID=
EC2_PUBLIC_SUBNET_ID=
# Lab container image source. Use either a full registry prefix or registry + tag.
OPSCOACH_LAB_ECR_PREFIX=
OPSCOACH_LAB_IMAGE_REGISTRY=
OPSCOACH_LAB_IMAGE_TAG=latest
# EventBridge Scheduler used to terminate idle/expired sessions.
SCHEDULER_GROUP_NAME=
SCHEDULER_INVOKE_ROLE_ARN=arn:aws:iam::123456789012:role/YourSchedulerInvokeRole
SESSION_TERMINATOR_LAMBDA_ARN=arn:aws:lambda:us-east-1:123456789012:function:YourTerminator

# ---------------------------------------------------------------------------
# Session lifecycle limits
# ---------------------------------------------------------------------------
OPSCOACH_MAX_ACTIVE_SESSIONS_PER_USER=2
OPSCOACH_MAX_LIFETIME_MINUTES=60
OPSCOACH_SSH_IDLE_GRACE_SECONDS=120

# ---------------------------------------------------------------------------
# Lab host callback (lab EC2 -> web app)
# ---------------------------------------------------------------------------
# Base URL the lab host / terminator use to call back into the web app. In-VPC this is the
# Cloud Map address, e.g. http://opscoach-web.ops.internal:3000
INTERNAL_CALLBACK_BASE_URL=
# Callback secret for the EC2 user-data ready webhook (global secret; per-session tokens are
# preferred). Generate one, e.g. `openssl rand -hex 24`. Short/placeholder values are
# rejected. In production this is injected from a secrets manager, not this file.
INTERNAL_CALLBACK_SECRET=

# ---------------------------------------------------------------------------
# SSH keys
# ---------------------------------------------------------------------------
# Optional grader SSH private key path (generated per session if unset)
GRADER_SSH_KEY_PATH=
# Default learner public key offered in the UI. NEXT_PUBLIC_* is exposed to the browser.
OPSCOACH_DEFAULT_LEARNER_PUBKEY=
NEXT_PUBLIC_DEFAULT_LEARNER_PUBKEY=

# ---------------------------------------------------------------------------
# Cognito / hosted UI (only when fronting the app with Cognito auth)
# ---------------------------------------------------------------------------
COGNITO_CLIENT_ID=
COGNITO_DOMAIN=your-pool.auth.us-east-1.amazoncognito.com

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# Public base URL of the app (used to build absolute callback/logout URLs).
APP_BASE_URL=http://localhost:3000
# Port the custom server listens on.
PORT=3000
